.ftpignore
.ftpconfig

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

data/
!data/.gitkeep
!data/img_features/.gitkeep
!data/models/.gitkeep

output/*
!output/.gitkeep
!output/snap/.gitkeep


.idea/
Oscar/
Prevalent/

airsim_plugin/settings

scripts/temp/*
*.tar

.vscode
nohup.out

temp/*
*.log

tmp/

# Local vision backbone repositories, caches, and checkpoints.
vision_backbones/dinov2/*
!vision_backbones/dinov2/.gitkeep
vision_backbones/resnet/*
!vision_backbones/resnet/.gitkeep
vision_backbones/torch_hub/*
!vision_backbones/torch_hub/.gitkeep
